# ==============================================================================
# .env.example — Plantilla de variables de entorno
#
# INSTRUCCIONES:
#   1. Copia este archivo como .env en la raiz del proyecto.
#   2. Completa los valores marcados con <...>.
#   3. NUNCA subas el archivo .env al repositorio (ya esta en .gitignore).
# ==============================================================================

# ---------------------------------------------------------------------------
# Proveedor activo — descomenta el modelo que quieras usar
# ---------------------------------------------------------------------------
# MODELO=gpt-4o-mini          # OpenAI (default)
# MODELO=gpt-4o
# MODELO=claude-haiku-4-5     # Anthropic
# MODELO=claude-sonnet-4-6    # Anthropic

# Temperatura del LLM (0.0 = determinista, 1.0 = creativo). Default: 0.2
# TEMPERATURA=0.2

# ---------------------------------------------------------------------------
# API Keys — completar solo la del proveedor elegido
# ---------------------------------------------------------------------------

# OpenAI — requerida si MODELO=gpt-* (default)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=<tu-clave-aqui>

# Anthropic — requerida si MODELO=claude-*
# Obtener en: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=<tu-clave-aqui>

# Gemini — requerida si MODELO=gemini/*
# Obtener en: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=<tu-clave-aqui>
